{
    "id": "royal-wedding",
    "name": "دعوة زفاف ملكية",
    "version": "1.0.0",
    "html": "index.html",
    "css": "style.css",
    "fields": [
        {
            "defaultValue": "💍",
            "label": "الأيقونة",
