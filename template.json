            "label": "أسماء العروسين",
            "minItems": 2,
            "hint": "أضف اسم العريس ثم اسم العروس.",
            "required": true,
            "separator": " ♥ ",
            "maxItems": 2,
            "key": "names"
        },
        {
            "type": "date",
