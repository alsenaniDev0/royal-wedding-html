            "options": [
                {
                    "label": "💍",
                    "value": "💍"
                },
                {
                    "value": "👑",
                    "label": "👑"
                },
                {
                    "value": "💐",
                    "label": "💐"
                },
                {
                    "label": "✨",
                    "value": "✨"
                }
            ],
            "key": "icon",
            "required": true
        },
        {
