{
    "id": "royal-wedding",
    "name": "دعوة زفاف ملكية",
    "version": "2.0.0",
    "html": "index.html",
    "css": "style.css",
    "features": {
        "feelings": {
            "enabled": true,
            "approvalMode": "manual",
            "preventDuplicate": true,
            "rateLimitMinutes": 5,
            "title": "شارك مشاعرك",
            "description": "اكتب رسالة جميلة لأصحاب الدعوة"
        },
        "rsvp": {
            "enabled": true,
            "preventDuplicate": true,
            "title": "هل ستحضر؟",
            "description": "يسعدنا معرفة حضورك للمناسبة",
            "options": [
                {
                    "label": "سأحضر",
                    "value": "attending",
                    "icon": "✅"
                },
                {
                    "label": "لن أستطيع الحضور",
                    "value": "not_attending",
                    "icon": "❎"
                },
                {
                    "label": "لم أقرر بعد",
                    "value": "maybe",
                    "icon": "❓"
                }
            ]
        }
    },
    "fields": [
        {
            "type": "icon",
            "label": "الأيقونة",
            "key": "icon",
            "options": [
                {
                    "value": "💍",
                    "label": "💍"
                },
                {
                    "value": "🤍",
                    "label": "🤍"
                },
                {
                    "value": "✨",
                    "label": "✨"
                },
                {
                    "value": "🌿",
                    "label": "🌿"
                },
                {
                    "value": "👑",
                    "label": "👑"
                },
                {
                    "value": "💐",
                    "label": "💐"
                }
            ],
            "defaultValue": "💍",
            "required": true
        },
        {
            "type": "text",
            "label": "عنوان الدعوة",
            "key": "title",
            "defaultValue": "دعوة زواج",
            "maxLength": 60,
            "required": true
        },
        {
            "type": "textarea",
            "label": "نص الدعوة",
            "key": "message",
            "defaultValue": "بكل الحب والسرور نتشرف بدعوتكم لمشاركتنا فرحة زواجنا",
            "minLength": 10,
            "maxLength": 220,
            "required": true
        },
        {
            "type": "names",
            "label": "أسماء العروسين",
            "key": "names",
            "placeholder": "مثال: محمد",
            "minItems": 2,
            "maxItems": 2,
            "separator": " و ",
            "hint": "أضف اسم العريس ثم اسم العروس.",
            "required": true
        },
        {
            "type": "date",
            "label": "تاريخ الحفل",
            "key": "date",
            "required": true
        },
        {
            "type": "time",
            "label": "وقت الحفل",
            "key": "time",
            "defaultValue": "20:00",
            "required": false
        },
        {
            "type": "map",
            "label": "الموقع",
            "key": "location",
            "placeholder": "اختر الموقع من الخريطة",
            "hint": "اضغط لاختيار الموقع من Google Map",
            "required": true
        },
        {
            "type": "textarea",
            "label": "رسالة الختام",
            "key": "closing",
            "defaultValue": "حضوركم يتمم فرحتنا ويزيد ليلتنا جمالاً",
            "minLength": 5,
            "maxLength": 180,
            "required": true
        },
        {
            "type": "youtube",
            "label": "رابط YouTube للصوت",
            "key": "soundUrl",
            "placeholder": "https://youtu.be/...",
            "hint": "ضع رابط YouTube وسيعمل كصوت للخلفية بعد فتح الدعوة",
            "pattern": "^https?:\\/\\/.+",
            "patternMessage": "الرابط يجب أن يبدأ بـ http أو https",
            "required": false
        },
        {
            "type": "color",
            "label": "اللون الأساسي",
            "key": "primaryColor",
            "defaultValue": "#7C2D12",
            "required": true
        },
        {
            "type": "color",
            "label": "اللون الثانوي",
            "key": "secondaryColor",
            "defaultValue": "#BE185D",
            "required": true
        },
        {
            "type": "color",
            "label": "لون الزخرفة",
            "key": "accentColor",
            "defaultValue": "#F6C453",
            "required": true
        },
        {
            "type": "color",
            "label": "لون الخلفية",
            "key": "backgroundColor",
            "defaultValue": "#FFF7ED",
            "required": true
        },
        {
            "type": "color",
            "label": "لون البطاقات",
            "key": "surfaceColor",
            "defaultValue": "#FFFFFF",
            "required": true
        },
        {
            "type": "color",
            "label": "لون النص",
            "key": "textColor",
            "defaultValue": "#24111A",
            "required": true
        },
        {
            "type": "color",
            "label": "لون النص الهادئ",
            "key": "mutedColor",
            "defaultValue": "#7C6A61",
            "required": true
        }
    ]
}